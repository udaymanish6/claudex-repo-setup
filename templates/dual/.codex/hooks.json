{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; python3 \"$PROJECT_ROOT/.codex/hooks/memory_guard.py\" SessionStart",
            "timeout": 5,
            "statusMessage": "Checking project memory bank"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; python3 \"$PROJECT_ROOT/.codex/hooks/memory_guard.py\" PreCompact",
            "timeout": 5,
            "statusMessage": "Checking memory before compact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; python3 \"$PROJECT_ROOT/.codex/hooks/memory_guard.py\" Stop",
            "timeout": 5,
            "statusMessage": "Checking memory status"
          },
          {
            "type": "command",
            "command": "PROJECT_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; python3 \"$PROJECT_ROOT/.codex/hooks/unified_notifier.py\" Stop",
            "timeout": 5,
            "statusMessage": "Sending completion notification"
          }
        ]
      }
    ]
  }
}
